/*==================================================
CURRENCY STORAGE
==================================================*/

const CurrencyStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.CURRENCY,

            "USD"

        );

    },

    set(currency){

        Storage.set(

            STORAGE_KEYS.CURRENCY,

            currency

        );

    }

};

/*==================================================
THEME STORAGE
==================================================*/

const ThemeStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.THEME,

            "light"

        );

    },

    Storage.set(
    STORAGE_KEYS.THEME,
    theme
);

        document.documentElement
        .setAttribute(

            "data-theme",

            theme

        );

    },

    toggle(){

        const current=

        this.get();

        const next=

        current==="light"
        ?"dark"
        :"light";

        this.set(next);

    }

};

/*==================================================
RECENT PRODUCTS
==================================================*/

const RecentStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.RECENT,

            []

        );

    },

    add(id){

        let items=this.get();

        items=items.filter(

            item=>item!==id

        );

        items.unshift(id);

        if(items.length>20){

            items.length=20;

        }

        Storage.set(

            STORAGE_KEYS.RECENT,

            items

        );

    },

    clear(){

        Storage.remove(

            STORAGE_KEYS.RECENT

        );

    }

};

/*==================================================
ORDERS STORAGE
==================================================*/

const OrdersStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.ORDERS,

            []

        );

    },

    save(order){

        const orders=this.get();

        orders.unshift(order);

        Storage.set(

            STORAGE_KEYS.ORDERS,

            orders

        );

    },

    clear(){

        Storage.remove(

            STORAGE_KEYS.ORDERS

        );

    }

};
/*==================================================
BACKUP
==================================================*/

function exportStorage(){

    const backup={

        cart:CartStorage.get(),

        wishlist:WishlistStorage.get(),

        compare:CompareStorage.get(),

        user:UserStorage.get(),

        settings:SettingsStorage.get(),

        language:LanguageStorage.get(),

        currency:CurrencyStorage.get(),

        theme:ThemeStorage.get(),

        recent:RecentStorage.get(),

        orders:OrdersStorage.get()

    };

    return JSON.stringify(

        backup,

        null,

        2

    );

}

/*==================================================
RESTORE
==================================================*/

function importStorage(json){

    try{

        const data=JSON.parse(json);

        if(data.cart){

            CartStorage.save(data.cart);

        }

        if(data.wishlist){

            WishlistStorage.save(data.wishlist);

        }

        if(data.compare){

            CompareStorage.save(data.compare);

        }

        if(data.user){

            UserStorage.save(data.user);

        }

        if(data.settings){

            SettingsStorage.save(data.settings);

        }

        if(data.language){

            LanguageStorage.set(data.language);

        }

        if(data.currency){

            CurrencyStorage.set(data.currency);

        }

        if(data.theme){

            ThemeStorage.set(data.theme);

        }

        if(data.recent){

            Storage.set(

                STORAGE_KEYS.RECENT,

                data.recent

            );

        }

        if(data.orders){

            Storage.set(

                STORAGE_KEYS.ORDERS,

                data.orders

            );

        }

        return true;

    }

    catch(error){

        console.error(error);

        return false;

    }

}

/*==================================================
RESET
==================================================*/

function resetApplicationStorage(){

    Object.values(

        STORAGE_KEYS

    ).forEach(function(key){

        Storage.remove(key);

    });

}

/*==================================================
SYNC BETWEEN TABS
==================================================*/

window.addEventListener(

    "storage",

    function(event){

        if(!event.key){

            return;

        }

        console.log(

            "Storage Updated:",

            event.key

        );

    }

);

/*==================================================
GLOBAL API
==================================================*/

window.StorageManager={

    Storage,

    Session,

    CartStorage,

    WishlistStorage,

    CompareStorage,

    UserStorage,

    SettingsStorage,

    LanguageStorage,

    CurrencyStorage,

    ThemeStorage,

    RecentStorage,

    OrdersStorage,

    exportStorage,

    importStorage,

    resetApplicationStorage

};

