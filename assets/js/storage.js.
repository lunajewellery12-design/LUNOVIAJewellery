/*==================================================
SETTINGS STORAGE
==================================================*/

const SettingsStorage={

    defaults:{

        language:"ar",

        currency:"USD",

        theme:"light"

    },

    get(){

        return Storage.get(

            STORAGE_KEYS.SETTINGS,

            this.defaults

        );

    },

    save(settings){

        Storage.set(

            STORAGE_KEYS.SETTINGS,

            settings

        );

    }

};
/*==================================================
LANGUAGE STORAGE
==================================================*/

const LanguageStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.LANGUAGE,

