"use strict";

/*==================================================
STORAGE KEYS
==================================================*/

const STORAGE_KEYS={

    CART:"lunovia_cart",

    WISHLIST:"lunovia_wishlist",

    COMPARE:"lunovia_compare",

    USER:"lunovia_user",

    SETTINGS:"lunovia_settings",

    LANGUAGE:"lunovia_language",

    CURRENCY:"lunovia_currency",

    THEME:"lunovia_theme",

    RECENT:"lunovia_recent",

    ORDERS:"lunovia_orders"

};

/*==================================================
LOCAL STORAGE
==================================================*/

const Storage={

    set(key,value){

        try{

            localStorage.setItem(

                key,

                JSON.stringify(value)

            );

            return true;

        }

        catch(error){

            console.error(error);

            return false;

        }

    },

    get(key,defaultValue=null){

        try{

            const value=

            localStorage.getItem(key);

            if(value===null){

                return defaultValue;

            }

            return JSON.parse(value);

        }

        catch(error){

            console.error(error);

            return defaultValue;

        }

    },

    remove(key){

        localStorage.removeItem(key);

    },

    clear(){

        localStorage.clear();

    },

    has(key){

        return localStorage.getItem(key)!==null;

    }

};

/*==================================================
SESSION STORAGE
==================================================*/

const Session={

    set(key,value){

        sessionStorage.setItem(

            key,

            JSON.stringify(value)

        );

    },

    get(key,defaultValue=null){

        const value=

        sessionStorage.getItem(key);

        if(value===null){

            return defaultValue;

        }

        return JSON.parse(value);

    },

    remove(key){

        sessionStorage.removeItem(key);

    },

    clear(){

        sessionStorage.clear();

    }

};
/*==================================================
CART STORAGE
==================================================*/

const CartStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.CART,

            []

        );

    },

    save(cart){

        Storage.set(

            STORAGE_KEYS.CART,

            cart

        );

    },

    clear(){

        Storage.remove(

            STORAGE_KEYS.CART

        );

    },

    count(){

        const cart=this.get();

        return cart.length;

    }

};

/*==================================================
WISHLIST STORAGE
==================================================*/

const WishlistStorage={

    get(){

        return Storage.get(

            STORAGE_KEYS.WISHLIST,

            []

        );

    },

    save(items){

